{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestGuard Quest",
  "type": "object",
  "required": [
    "quest_id",
    "title",
    "summary",
    "quest_type",
    "giver_npc",
    "start_location",
    "objectives",
    "preconditions",
    "completion_conditions",
    "rewards",
    "reusable_tags",
    "design_notes"
  ],
  "properties": {
    "quest_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "quest_type": {
      "type": "string",
      "enum": [
        "delivery",
        "exploration",
        "rescue",
        "investigation",
        "dialogue",
        "combat",
        "collection",
        "escort",
        "puzzle"
      ]
    },
    "giver_npc": {
      "type": "string",
      "minLength": 1
    },
    "start_location": {
      "type": "string",
      "minLength": 1
    },
    "objectives": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "depends_on",
          "action",
          "target",
          "success_condition"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^step_[0-9]{3}$"
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^step_[0-9]{3}$"
            }
          },
          "action": {
            "type": "string",
            "enum": [
              "talk",
              "return",
              "collect",
              "deliver",
              "visit",
              "travel",
              "investigate",
              "inspect",
              "interact",
              "defeat",
              "protect",
              "rescue",
              "escort",
              "use",
              "unlock"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "success_condition": {
            "type": "string",
            "minLength": 12
          }
        },
        "additionalProperties": false
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "completion_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 12
      }
    },
    "rewards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "item",
              "currency",
              "reputation",
              "unlock"
            ]
          },
          "value": {
            "type": [
              "string",
              "number"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "reusable_tags": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "design_notes": {
      "type": "object",
      "required": [
        "intended_player_experience",
        "reuse_potential",
        "integration_notes"
      ],
      "properties": {
        "intended_player_experience": {
          "type": "string",
          "minLength": 12
        },
        "reuse_potential": {
          "type": "string",
          "minLength": 12
        },
        "integration_notes": {
          "type": "string",
          "minLength": 12
        }
      },
      "additionalProperties": false
    },
    "generation_batch": {
      "type": "integer"
    },
    "generation_index_in_batch": {
      "type": "integer"
    },
    "generation_global_index": {
      "type": "integer"
    },
    "generation_mode": {
      "type": "string"
    },
    "generation_model": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
